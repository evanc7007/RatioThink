# Xcode (regenerated by Scripts/genproject.sh — do not commit)
*.xcodeproj/
*.xcworkspace/
DerivedData/
build/
*.xcuserstate
*.xccheckout

# Swift
.build/
Packages/
Package.pins
Package.resolved
*.swiftpm/

# macOS
.DS_Store
*.dSYM

# Cargo (for pie submodule local builds)
Vendor/pie/target/
target/

# Generated build artifacts
Resources/pie-engine/
Resources/inferlets/

# Codesign secrets / credentials (never commit signing material or keys)
*.p12
*.provisionprofile
*.mobileprovision
*.cer
*.certSigningRequest
*.pem
*.key
AuthKey_*.p8
*.p8
.env
.env.*

# Logs
*.log
test-*.log

# Local test models (multi-GB GGUF files)
test-models/*.gguf

# Editor
.vscode/
.idea/
*.swp

# Worker-injected agent config (not part of canonical repo)
.claude/

# Per-session ephemera
test-logs/
.DerivedData-smoke/
default.profraw
.logs/

# Local-only docs backup (not part of the public repo)
docs.bak/

# Local-only planning scratch (not part of the public repo)
docs/plans/

# Python bytecode (e.g. Scripts/make-dmg-dsstore.py imported by tests)
__pycache__/
*.pyc

# Generated Repeat Boost / speculative-decoding bench artifact (Scripts/run-spec-bench.sh)
spec_bench_*.json

# Spec-decode benefit matrix (#652): emitted dataset prompt sets are regenerated
# from the pinned revision in datasets.lock — only the lock is committed.
Scripts/benchmark/data/
spec_matrix_*.json
